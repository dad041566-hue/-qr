{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "next.config.ts",
    "src/app/layout.tsx",
    "src/app/page.tsx",
    "src/app/(public)/**/*.ts",
    "src/app/(public)/**/*.tsx",
    "src/app/(customer)/**/*.ts",
    "src/app/(customer)/**/*.tsx",
    "src/app/(auth)/**/*.ts",
    "src/app/(auth)/**/*.tsx",
    "src/app/admin/**/*.ts",
    "src/app/admin/**/*.tsx",
    "src/app/superadmin/**/*.ts",
    "src/app/superadmin/**/*.tsx",
    "src/app/components/admin/**/*.ts",
    "src/app/components/admin/**/*.tsx",
    "src/app/components/home/**/*.tsx",
    "src/app/components/ui/**/*.ts",
    "src/app/components/ui/**/*.tsx",
    "src/providers/**/*.tsx",
    "src/app/actions/**/*.ts",
    "src/lib/supabase/**/*.ts",
    "src/lib/env.ts",
    "src/lib/utils/**/*.ts",
    "src/middleware.ts",
    "src/types/**/*.ts",
    "src/types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "src/app/App.tsx",
    "src/app/routes.tsx",
    "src/app/pages/**",
    "src/app/components/Dashboard.tsx",
    "src/app/components/Sidebar.tsx",
    "src/app/components/ProtectedRoute.tsx",
    "src/app/components/SuperAdminRoute.tsx",
    "src/app/components/figma/**",
    "src/app/components/StaffCreateModal.tsx",
    "src/contexts/AuthContext.tsx"
  ]
}
